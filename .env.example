# Chess engine backend: ts (default, fast startup, no native binary needed) | native (requires Docker .node build)
# Default in dev/CI: ts. Default in prod: native.
# ENGINE_BACKEND=ts
DATABASE_URL=postgresql://user:password@localhost:5432/purechess
DATABASE_URL_DIRECT=postgresql://user:password@localhost:5432/purechess
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-min-32-chars-random-string-here
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=
OAUTH_APPLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/apple/callback
# Password reset emails (Resend). Leave RESEND_API_KEY blank in dev — links log to stdout.
RESEND_API_KEY=
EMAIL_FROM=PureChess <noreply@purechesss.com>
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=https://purechesss.com
API_INTERNAL_URL=http://localhost:4000

# Sentry (leave blank in dev to skip init)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=purechess
SENTRY_PROJECT=purechess-web
SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (EU residency by default — change host for US)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# Production / Deployment
WEB_URL=https://purechesss.com
FLY_API_TOKEN=

# Cloudflare R2 (database backups)
R2_BUCKET=purechess-backups
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Upstash Redis (TLS in production)
# Use rediss:// (double-s) for TLS
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
