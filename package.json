{
  "name": "purechess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:web": "pnpm --filter @purechess/web dev",
    "dev:api": "pnpm --filter @purechess/api dev",
    "build": "pnpm --filter @purechess/shared build && pnpm --parallel --filter './apps/*' build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
    "db:migrate:deploy": "pnpm --filter @purechess/api exec prisma migrate deploy",
    "e2e": "pnpm --filter @purechess/web e2e",
    "e2e:setup": "pnpm --filter @purechess/web e2e:setup",
    "smoke": "bash scripts/smoke.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^7.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
